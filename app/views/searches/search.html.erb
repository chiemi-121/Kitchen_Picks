<div class="container mt-4">
  <h2>検索結果</h2>
  <p class="text-muted">
    対象：
    <% case @range %>
    <% when "User" %>
      ユーザー
    <% when "Tag" %>
      ジャンル
    <% else %>
      投稿
    <% end %>
    /
    手法：
    <% case @search %>
    <% when "perfect" %>
      完全一致
    <% when "forward" %>
      前方一致
    <% when "backward" %>
      後方一致
    <% else %>
      部分一致
    <% end %>
    / キーワード：<%= @word.presence || "(未入力)" %>
  </p>
  <hr>

  <% if @word.blank? %>
    <p>キーワードを入力してください。</p>
  <% elsif @range == "User" %>
    <% if @users.any? %>
      <ul class="list-group">
        <% @users.each do |user| %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <strong><%= user.name %></strong>
              <div class="text-muted small"><%= user.email %></div>
            </div>
            <%= link_to "詳細", user_path(user), class: "btn btn-sm btn-outline-primary" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>該当するユーザーは見つかりませんでした。</p>
    <% end %>
  <% else %>
    <% if @posts.any? %>
      <div class="list-group">
        <% @posts.each do |post| %>
          <div class="list-group-item">
            <h5 class="mb-1"><%= link_to post.title, post_path(post), class: "text-decoration-none" %></h5>
            <p class="mb-1 text-muted"><%= truncate(post.body, length: 100) %></p>
            <small class="text-muted">
              投稿者：<%= post.user.name %>
              <% if post.category.present? %>
                / カテゴリー：<%= post.category.name %>
              <% end %>
            </small>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>該当する投稿は見つかりませんでした。</p>
    <% end %>
  <% end %>
</div>