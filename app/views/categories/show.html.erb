<div class="container mt-4">
  <h2>カテゴリー: <%= @category.name %></h2>
  <hr>

  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <div class="card mb-3">
        <div class="card-body">
          <h5><%= link_to post.title, post_path(post), class: "text-decoration-none" %></h5>
          <p class="text-muted mb-0"><%= truncate(post.body, length: 100) %></p>
        </div>
      </div>
    <% end %>
  <% else %>
    <p>このカテゴリーの投稿はまだありません。</p>
  <% end %>
</div>