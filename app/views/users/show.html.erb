<div class="container mt-4">

  <h2><%= @user.name %> さんのプロフィール</h2>

  <hr>

  <p><strong>名前：</strong> <%= @user.name %></p>
  <p><strong>メールアドレス：</strong> <%= @user.email %></p>
  <p><strong>コメント数：</strong> <%= @user.comments.count %>件</p>

  <hr>

  <h3 class="h5">投稿一覧</h3>

  <% if @posts.any? %>
    <ul class="list-group">
      <% @posts.each do |post| %>
        <li class="list-group-item d-flex justify-content-between align-items-center gap-3">
          <div>
            <%= link_to post.title, post_path(post), class: "text-decoration-none fw-bold" %>
            <div class="small text-muted d-flex flex-wrap align-items-center gap-2 mt-1">
              <span class="d-inline-flex align-items-center gap-1">評価：<%= render "posts/rating", rating: post.rating %></span>
              <span>カテゴリー：<%= post.category.name %></span>
              <span>投稿日：<%= post.created_at.strftime("%Y-%m-%d") %></span>
            </div>
          </div>

          <%= link_to "投稿を見る", post_path(post), class: "btn btn-sm btn-outline-secondary" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted mb-0">まだ投稿がありません。</p>
  <% end %>

  <hr>

  <div class="mt-3">
    <%= link_to "プロフィール編集", edit_user_path(@user), class: "btn btn-secondary" %>
    <%= link_to "マイページへ戻る", mypage_path, class: "btn btn-outline-primary ms-2" %>
  </div>

</div>