<!DOCTYPE html>
<html>
  <head>
    <title>KitchenPicks</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <!-- ====== ヘッダー ====== -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">Kitchen Picks</a>

        <div class="navbar-collapse">
          <ul class="navbar-nav ms-auto">

            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "About", about_path, class: "nav-link" %></li>

            <% if user_signed_in? %>
              <li class="nav-item"><%= link_to "投稿一覧", posts_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "新規投稿", new_post_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "マイページ", mypage_path, class: "nav-link" %></li>
              <li class="nav-item">
                <%= link_to "Log out",
                      logout_path,
                      method: :delete,
                      data: { turbo_method: :delete },
                      class: "nav-link text-warning" %>
              </li>
            <% else %>
              <li class="nav-item"><%= link_to "投稿一覧", posts_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "Log in", login_path, class: "nav-link" %></li>
            <% end %>

          </ul>
        </div>
      </div>
    </nav>

    <!-- ====== ページ内容 ====== -->
    <main class="container mt-4 flex-grow-1">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type == 'alert' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer bg-dark text-light py-4 mt-5">
      <div class="container text-center">
        <p class="mb-1 fw-semibold">Kitchen Picks</p>
        <p class="mb-0 small text-secondary">キッチン便利グッズのレビューを共有するポートフォリオアプリ</p>
      </div>
    </footer>

  </body>
</html>