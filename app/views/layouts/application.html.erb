<!DOCTYPE html>
<html>
  <head>
    <title>KitchenPicks</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>

    <!-- Bootstrap（Rails8は自動で入らないので必須） -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- ====== ヘッダー（PC版アプリ風） ====== -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">

        <!-- ブランドロゴ -->
        <a class="navbar-brand fw-bold" href="/">
          Kitchen Picks
        </a>

        <!-- PCでは常に展開される（スマホ対応は後で） -->
        <div class="navbar-collapse">
          <ul class="navbar-nav ms-auto">

            <!-- 共通リンク -->
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>

            <% if user_signed_in? %>
              <!-- ログイン後だけ表示 -->
              <li class="nav-item">
                <%= link_to "投稿一覧", posts_path, class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "新規投稿", new_post_path, class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "マイページ", mypage_path, class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "Log out",
                      logout_path,
                      method: :delete,
                      data: { turbo_method: :delete },
                      class: "nav-link text-warning" %>
              </li>

            <% else %>
              <!-- 未ログイン時 -->
              <li class="nav-item">
                <%= link_to "新規登録", signup_path, class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "Log in", login_path, class: "nav-link" %>
              </li>
            <% end %>

          </ul>
        </div>
      </div>
    </nav>
    
    <main class="container mt-4">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type == 'alert' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>




    <!-- ====== ページ内容 ====== -->
    <main class="container mt-4">
      <%= yield %>
    </main>

  </body>
</html>