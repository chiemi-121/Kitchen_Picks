<!DOCTYPE html>
<html>
  <head>
    <title>KitchenPicks Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-app">
      <div class="container">
        <%= link_to "Kitchen Picks Admin", admin_root_path, class: "navbar-brand fw-semibold" %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="adminNavbar">
          <ul class="navbar-nav ms-auto">
            <% if admin_signed_in? %>
              <li class="nav-item"><%= link_to "レビュー一覧", admin_posts_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "ユーザー一覧", admin_users_path, class: "nav-link" %></li>
              <li class="nav-item">
                <%= link_to "ログアウト", admin_logout_path,
                    method: :delete,
                    data: { turbo_method: :delete },
                  class: "nav-link" %>
              </li>
            <% else %>
              <li class="nav-item"><%= link_to "管理者ログイン", admin_login_path, class: "nav-link" %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4 flex-grow-1 content-shell">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type == 'alert' ? 'danger' : 'success' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer-app py-3 mt-auto">
      <div class="container text-center">
        <small class="text-muted">Kitchen Picks Admin</small>
      </div>
    </footer>
  </body>
</html>