<!DOCTYPE html>
<html>
  <head>
    <title>KitchenPicks</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
   

    <%= stylesheet_link_tag 'application', media: 'all' %>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">

        <a class="navbar-brand fw-bold" href="/">Kitchen Picks</a>

        <div class="navbar-collapse">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "About", about_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "新規登録", signup_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Log in", login_path, class: "nav-link" %></li>
          </ul>
        </div>

      </div>
    </nav>

    <main class="container mt-4">
      <%= yield %>
    </main>

  </body>
</html>