<div class="container text-center mt-5">

  <!-- ロゴ画像（上に余白を追加） -->
  <%= image_tag asset_path("kitchen_picks_logo.png"),
      alt: "Kitchen Picks ロゴ",
      class: "logo-img mx-auto d-block mt-5 mb-4" %>

  <h1 class="fw-bold mb-4">Kitchen Picks へようこそ！</h1>

  <p class="lead mb-5">
    キッチン便利グッズのレビュー・投稿アプリです。<br>
    気に入ったアイテムの使い心地を共有しましょう。
  </p>

  <% unless user_signed_in? %>
    <div class="d-flex justify-content-center gap-3">

      <%= link_to "ログイン", login_path,
          class: "btn btn-outline-primary btn-lg rounded-pill px-4" %>

    </div>
  <% end %>

</div>