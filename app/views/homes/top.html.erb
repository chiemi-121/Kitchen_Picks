<div class="text-center mt-5">

  <h1 class="mb-4">Kitchen Picks へようこそ！</h1>
  <p class="lead mb-5">
    キッチン便利グッズのレビュー・投稿アプリです。<br>
    気に入ったアイテムの使い心地を共有しましょう。
  </p>

  <% if user_signed_in? %>
    <!-- ログイン済みなら投稿一覧へ -->
    <%= link_to "投稿一覧へ", posts_path, class: "btn btn-primary btn-lg me-3" %>
    <%= link_to "マイページへ", mypage_path, class: "btn btn-outline-secondary btn-lg" %>

  <% else %>
    <!-- 未ログインなら Sign up / Log in の2ボタンだけ -->
    <%= link_to "新規登録（Sign up）", signup_path, class: "btn btn-success btn-lg me-3" %>
    <%= link_to "ログイン（Log in）", login_path, class: "btn btn-outline-primary btn-lg" %>
  <% end %>

</div>