<h2>ジャンル一覧</h2>

<p>気になるジャンルからレビューを探しましょう。</p>

<ul class="list-group">
  <% @tags.each do |tag| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <%= link_to tag.name, tag_path(tag) %>
      <span class="badge bg-secondary"><%= tag.posts.count %> 件</span>
    </li>
  <% end %>
</ul>