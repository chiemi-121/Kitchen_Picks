<%= form_with model: post, local: true do |f| %>

  <!-- タイトル -->
  <div class="mb-3">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <!-- レビュー本文 -->
  <div class="mb-3">
    <%= f.label :body, "レビュー内容" %>
    <%= f.text_area :body, class: "form-control", rows: 6 %>
  </div>

  <!-- カテゴリ -->
  <div class="mb-3">
    <%= f.label :category_id, "カテゴリー" %>
    <%= f.collection_select :category_id, Category.all, :id, :name,
          prompt: "選択してください",
          class: "form-select" %>
  </div>

  <!-- タグ（ジャンル） -->
  <div class="mb-3">
    <%= f.label :tag_ids, "ジャンル" %>

    <div class="genre-list">
      <% Tag.all.each do |tag| %>
        <label class="genre-item d-block">
          <%= check_box_tag "post[tag_ids][]",
                tag.id,
                post.tag_ids.include?(tag.id) %>
          <%= tag.name %>
        </label>
      <% end %>
    </div>
  </div>

  <!-- 画像アップロード（必要なら） -->
  <% if post.respond_to?(:image) %>
    <div class="mb-3">
      <%= f.label :image, "画像" %>
      <%= f.file_field :image, class: "form-control" %>

      <% if post.image.attached? %>
        <div class="mt-2">
          <%= image_tag post.image, class: "img-thumbnail", width: 200 %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- 評価（必要なら） -->
  <% if post.respond_to?(:rating) %>
    <div class="mb-3">
      <%= f.label :rating, "評価（1〜5）" %>
      <%= f.number_field :rating, in: 1..5, class: "form-control", step: 1 %>
    </div>
  <% end %>

  <!-- 送信ボタン -->
  <%= f.submit (post.new_record? ? "投稿する" : "更新する"),
        class: "btn btn-primary" %>

<% end %>