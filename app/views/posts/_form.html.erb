<% if @post.errors.any? %>
  <div class="alert alert-danger">
    <ul>
      <% @post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @post, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :body, "本文" %>
    <%= f.text_area :body, class: "form-control", rows: 6 %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, "評価（1〜5）" %>
    <%= f.number_field :rating, class: "form-control", min: 1, max: 5 %>
  </div>

  <div class="mb-3">
    <%= f.label :category_id, "カテゴリ" %>
    <%= f.collection_select :category_id, Category.all, :id, :name, class: "form-select" %>
  </div>

  <%= f.submit class: "btn btn-success" %>
<% end %>