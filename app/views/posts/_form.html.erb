<%= form_with model: post, local: true do |f| %>

  <!-- タイトル -->
  <div class="mb-3">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <!-- レビュー本文 -->
  <div class="mb-3">
    <%= f.label :body, "レビュー内容" %>
    <%= f.text_area :body, class: "form-control", rows: 6 %>
  </div>

  <!-- カテゴリー -->
  <div class="mb-3">
    <%= f.label :category_id, "カテゴリー" %>
    <%= f.collection_select :category_id, Category.all, :id, :name,
          prompt: "選択してください",
          class: "form-select" %>
  </div>

  <!-- タグ（ジャンル） -->
  <div class="mb-3">
    <%= f.label :tag_ids, "ジャンル" %>

    <div class="genre-list">
      <% Tag.all.each do |tag| %>
        <label class="genre-item d-block">
          <%= check_box_tag "post[tag_ids][]",
                tag.id,
                post.tag_ids.include?(tag.id) %>
          <%= tag.name %>
        </label>
      <% end %>
    </div>
  </div>

  <!-- 画像アップロード（複数対応＋削除ボタン） -->
  <div class="mb-3">
    <%= f.label :images, "画像（複数可）" %>
    <%= f.file_field :images, multiple: true, class: "form-control" %>

    <% if post.images.attached? %>
      <div class="mt-2 d-flex gap-3 flex-wrap">
        <% post.images.each do |image| %>
          <div class="text-center">
            <%= image_tag image, class: "img-thumbnail", width: 150 %><br>

            <!-- ★ 削除チェックボックス -->
            <label class="mt-1">
              <%= check_box_tag "post[remove_image_ids][]", image.id %>
              削除する
            </label>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 評価 -->
  <div class="mb-3">
    <%= f.label :rating, "評価（1〜5）" %>
    <%= f.number_field :rating, in: 1..5, class: "form-control", step: 1 %>
  </div>

  <!-- 送信ボタン -->
  <%= f.submit (post.new_record? ? "投稿する" : "更新する"),
        class: "btn btn-primary" %>

<% end %>