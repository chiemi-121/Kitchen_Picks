<%= form_with model: post, local: true, html: { multipart: true } do |f| %>

  <% if post.errors.any? %>
    <div class="alert alert-danger">
      <p class="mb-2">入力内容を確認してください。</p>
      <ul class="mb-0">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- タイトル -->
  <div class="mb-3">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <!-- レビュー本文 -->
  <div class="mb-3">
    <%= f.label :body, "レビュー内容" %>
    <%= f.text_area :body, class: "form-control", rows: 6 %>
  </div>

  <!-- カテゴリー -->
  <div class="mb-3">
    <%= f.label :category_id, "カテゴリー" %>
    <%= f.collection_select :category_id, Category.all, :id, :name,
          prompt: "選択してください",
          class: "form-select" %>
  </div>

  <!-- タグ（ジャンル） -->
  <div class="mb-3">
    <%= f.label :tag_ids, "ジャンル" %>

    <div class="genre-list">
      <% Tag.all.each do |tag| %>
        <label class="genre-item d-block">
          <%= check_box_tag "post[tag_ids][]",
                tag.id,
                post.tag_ids.include?(tag.id) %>
          <%= tag.name %>
        </label>
      <% end %>
    </div>
  </div>

  <!-- 画像アップロード（複数対応＋削除ボタン） -->
    <div class="mb-3">
    <%= f.label :images, "画像（複数可）" %>
    <%= f.file_field :images, multiple: true, class: "form-control" %>

    <% if post.persisted? && post.images.attached? %>
      <div class="mt-2 d-flex gap-3 flex-wrap">
        <% post.images.each do |image| %>
          <div class="text-center">
            <%= image_tag image, class: "img-thumbnail", width: 150 %><br>

            <!-- ★ 削除チェックボックス（編集時のみ） -->
            <label class="mt-1">
              <%= check_box_tag "post[remove_image_ids][]", image.id %>
              削除する
            </label>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
    

  <!-- 評価 -->
  <div class="mb-3">
    <%= f.label :rating, "評価" %>

    <% if post.new_record? %>
      <div
        class="post-rating-input"
        data-rating-input
        data-rating-score="<%= post.rating || 0 %>"
        data-rating-score-name="post[rating]"
        data-rating-star-on="<%= asset_path("star-on.svg") %>"
        data-rating-star-off="<%= asset_path("star-off.svg") %>"
        data-rating-star-half="<%= asset_path("star-half.svg") %>">
      </div>
      <p class="form-text mb-0">星を選んで 1〜5 の評価をつけてください。</p>
    <% else %>
      <%= render "rating", rating: post.rating, class_name: "post-rating--lg" %>
      <p class="form-text mb-0">評価は投稿時のみ設定でき、あとから変更できません。</p>
    <% end %>
  </div>

  <!-- 送信ボタン -->
  <%= f.submit (post.new_record? ? "投稿する" : "更新する"),
        class: "btn btn-primary" %>

<% end %>