<%= turbo_frame_tag dom_id(post, :comments_list) do %>
  <% if comments.any? %>
    <ul class="list-group mb-3">
      <% comments.each do |comment| %>
        <li class="list-group-item d-flex justify-content-between align-items-start" id="<%= dom_id(comment) %>">
          <div>
            <div class="fw-bold"><%= comment.user.name %></div>
            <div><%= simple_format(comment.body) %></div>
            <small class="text-muted"><%= comment.created_at.strftime("%Y-%m-%d %H:%M") %></small>
          </div>

          <% if current_user && comment.user_id == current_user.id %>
            <%= button_to "削除", comment_path(comment),
                method: :delete,
                class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">まだコメントはありません。</p>
  <% end %>
<% end %>
