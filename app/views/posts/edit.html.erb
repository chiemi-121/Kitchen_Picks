<div class="container mt-4">

  <h2>投稿編集</h2>
  <p class="text-muted">評価は投稿時にのみ設定できます。</p>
  <hr>

  <%= render "form", post: @post %>

  <div class="mt-3">
    <%= button_to "削除する", post_path(@post),
          method: :delete,
          data: { confirm: "本当に削除しますか？" },
          class: "btn btn-danger" %>
  </div>

</div>