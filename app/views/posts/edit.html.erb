<div class="container mt-4">

  <h2>投稿編集</h2>
  <hr>

  <%= form_with model: @post, local: true do |f| %>

    <div class="mb-3">
      <%= f.label :title, "タイトル" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :body, "本文" %>
      <%= f.text_area :body, class: "form-control", rows: 6 %>
    </div>

    <div class="mb-3">
      <%= f.label :rating, "評価（1〜5）" %>
      <%= f.number_field :rating, class: "form-control", min: 1, max: 5 %>
    </div>

    <div class="mb-3">
      <%= f.label :category_id, "カテゴリ" %>
      <%= f.collection_select :category_id, Category.all, :id, :name, class: "form-select" %>
    </div>

    <%= f.submit "更新する", class: "btn btn-success" %>

  <% end %>

  <hr>

  <!-- 削除ボタン -->
  <%= link_to "削除する", post_path(@post),
      method: :delete,
      data: { confirm: "本当に削除しますか？" },
      class: "btn btn-danger" %>

  <%= link_to "投稿詳細へ戻る", post_path(@post), class: "btn btn-secondary ms-2" %>

</div>