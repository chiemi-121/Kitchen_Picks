<div class="post-show mx-auto">

  <h2><%= @post.title %></h2>
  <hr>

  <!-- ★ 画像ギャラリー（複数対応） -->
  <% if @post.images.attached? %>
    <div class="post-show__images d-flex justify-content-center flex-wrap gap-3 mb-4">
      <% @post.images.each do |image| %>
        <%= image_tag url_for(image), class: "img-thumbnail post-show__image" %>
      <% end %>
    </div>
  <% end %>

  <p><%= simple_format(@post.body) %></p>

  <!-- ★ カテゴリ表示 -->
  <p><strong>カテゴリー：</strong> <%= @post.category.name %></p>

  <!-- ★ ジャンル表示（リンク付き・複数） -->
  <p><strong>ジャンル：</strong>
    <% @post.tags.each do |tag| %>
      <%= link_to tag_path(tag), class: "text-decoration-none" do %>
        <span class="badge bg-primary"><%= tag.name %></span>
      <% end %>
    <% end %>
  </p>

  <p class="text-muted">
    <span class="d-inline-flex align-items-center gap-1">評価：<%= render "rating", rating: @post.rating, class_name: "post-rating--lg" %></span><br>
    いいね：<%= render "favorite_count", post: @post %><br>
    投稿者：<%= link_to @post.user.name, user_path(@post.user), class: "text-decoration-none" %><br>
    投稿日時：<%= @post.created_at.strftime("%Y-%m-%d %H:%M") %>
  </p>

  <div class="mb-3">
    <%= render "favorite_button_show", post: @post %>
  </div>

  <hr>

  <!-- 編集・削除ボタン（ログインユーザーの投稿のみ表示） -->
  <% if current_user && @post.user_id == current_user.id %>
    <div class="post-show__actions d-flex flex-wrap gap-3">
      <%= link_to "編集する", edit_post_path(@post), class: "btn btn-primary" %>

      <%= button_to "削除する", post_path(@post),
          method: :delete,
          data: { confirm: "本当に削除しますか？" },
          class: "btn btn-danger" %>
    </div>
  <% end %>

  <hr>

  <h4>コメント（<%= render "comments_count", post: @post, comments: @comments %>）</h4>

  <%= render "comments_list", post: @post, comments: @comments %>

  <%= render "comment_form", post: @post, comment: @comment %>

  <hr>

  <%= link_to "投稿一覧へ戻る", posts_path, class: "btn btn-secondary" %>

</div>