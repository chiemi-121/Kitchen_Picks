<div class="container mt-4">

  <h2><%= @post.title %></h2>
  <hr>

  <!-- ★ 画像ギャラリー（複数対応） -->
  <% if @post.images.attached? %>
    <div class="d-flex gap-3 flex-wrap mb-4">
      <% @post.images.each do |image| %>
        <%= image_tag image, class: "img-thumbnail", width: 300 %>
      <% end %>
    </div>
  <% end %>

  <p><%= simple_format(@post.body) %></p>

  <!-- ★ カテゴリ表示 -->
  <p><strong>カテゴリー：</strong> <%= @post.category.name %></p>

  <!-- ★ ジャンル表示（リンク付き・複数） -->
  <p><strong>ジャンル：</strong>
    <% @post.tags.each do |tag| %>
      <%= link_to tag_path(tag), class: "text-decoration-none" do %>
        <span class="badge bg-primary"><%= tag.name %></span>
      <% end %>
    <% end %>
  </p>

  <p class="text-muted">
    評価：<%= "★" * @post.rating %><%= "☆" * (5 - @post.rating) %><br>
    投稿者：<%= @post.user.name %><br>
    投稿日時：<%= @post.created_at.strftime("%Y-%m-%d %H:%M") %>
  </p>

  <hr>

  <!-- 編集・削除ボタン（ログインユーザーの投稿のみ表示） -->
  <% if @post.user_id == current_user.id %>
    <%= link_to "編集する", edit_post_path(@post), class: "btn btn-primary me-2" %>

    <%= button_to "削除する", post_path(@post),
        method: :delete,
        data: { confirm: "本当に削除しますか？" },
        class: "btn btn-danger" %>
  <% end %>

  <hr>

  <%= link_to "投稿一覧へ戻る", posts_path, class: "btn btn-secondary" %>

</div>