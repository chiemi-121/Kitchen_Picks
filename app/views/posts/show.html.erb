<div class="container mt-4">

  <h2><%= @post.title %></h2>
  <hr>

  <!-- ★ 画像ギャラリー（複数対応） -->
  <% if @post.images.attached? %>
    <div class="d-flex gap-3 flex-wrap mb-4">
      <% @post.images.each do |image| %>
        <%= image_tag url_for(image), class: "img-thumbnail", width: 300 %>
      <% end %>
    </div>
  <% end %>

  <p><%= simple_format(@post.body) %></p>

  <!-- ★ カテゴリ表示 -->
  <p><strong>カテゴリー：</strong> <%= @post.category.name %></p>

  <!-- ★ ジャンル表示（リンク付き・複数） -->
  <p><strong>ジャンル：</strong>
    <% @post.tags.each do |tag| %>
      <%= link_to tag_path(tag), class: "text-decoration-none" do %>
        <span class="badge bg-primary"><%= tag.name %></span>
      <% end %>
    <% end %>
  </p>

  <p class="text-muted">
    評価：<%= "★" * @post.rating %><%= "☆" * (5 - @post.rating) %><br>
    投稿者：<%= link_to @post.user.name, user_path(@post.user), class: "text-decoration-none" %><br>
    投稿日時：<%= @post.created_at.strftime("%Y-%m-%d %H:%M") %>
  </p>

  <hr>

  <!-- 編集・削除ボタン（ログインユーザーの投稿のみ表示） -->
  <% if current_user && @post.user_id == current_user.id %>
    <%= link_to "編集する", edit_post_path(@post), class: "btn btn-primary me-2" %>

    <%= button_to "削除する", post_path(@post),
        method: :delete,
        data: { confirm: "本当に削除しますか？" },
        class: "btn btn-danger" %>
  <% end %>

  <hr>

  <h4>コメント（<%= @comments.count %>件）</h4>

  <% if @comments.any? %>
    <ul class="list-group mb-3">
      <% @comments.each do |comment| %>
        <li class="list-group-item d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-bold"><%= comment.user.name %></div>
            <div><%= simple_format(comment.body) %></div>
            <small class="text-muted"><%= comment.created_at.strftime("%Y-%m-%d %H:%M") %></small>
          </div>

          <% if current_user && comment.user_id == current_user.id %>
            <%= button_to "削除", comment_path(comment),
                method: :delete,
                data: { confirm: "このコメントを削除しますか？" },
                class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">まだコメントはありません。</p>
  <% end %>

  <% if current_user %>
    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">コメントを投稿する</h5>

        <%= form_with model: @comment, local: true do |f| %>
          <%= f.hidden_field :post_id, value: @post.id %>

          <div class="mb-2">
            <%= f.text_area :body, rows: 3, class: "form-control", placeholder: "コメントを入力してください" %>
          </div>

          <%= f.submit "送信", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <p>
      <%= link_to "ログイン", login_path %>するとコメントできます。
    </p>
  <% end %>

  <hr>

  <%= link_to "投稿一覧へ戻る", posts_path, class: "btn btn-secondary" %>

</div>