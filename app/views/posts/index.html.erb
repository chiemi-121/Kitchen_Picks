<div class="post-index">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-4">
    <div>
      <h2 class="mb-1">投稿一覧</h2>
      <p class="text-muted mb-0">最新の投稿から順に表示しています。</p>
    </div>
  </div>

  <% if @posts.any? %>
    <div class="row row-cols-1 row-cols-lg-2 g-4">
      <% @posts.each do |post| %>
        <div class="col">
          <article class="card post-card h-100">
            <div class="card-body p-4 d-flex flex-column gap-3">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div class="flex-grow-1">
                  <h3 class="h5 mb-2">
                    <%= link_to post.title, post_path(post), class: "post-card__title text-decoration-none" %>
                  </h3>

                  <div class="post-card__meta text-muted small">
                    <span>評価：<%= "★" * post.rating %><%= "☆" * (5 - post.rating) %></span>
                    <span>・</span>
                    <span>コメント <%= post.comments.size %>件</span>
                  </div>
                </div>

                <% if post.category.present? %>
                  <span class="badge text-bg-light border post-card__category"><%= post.category.name %></span>
                <% end %>
              </div>

              <p class="text-muted mb-0"><%= truncate(post.body, length: 110) %></p>

              <% if post.images.attached? %>
                <div class="post-card__images">
                  <% post.images.each do |image| %>
                    <%= image_tag url_for(image), class: "post-card__image" %>
                  <% end %>
                </div>
              <% end %>

              <% if post.tags.any? %>
                <div class="d-flex flex-wrap gap-2">
                  <% post.tags.each do |tag| %>
                    <%= link_to tag_path(tag), class: "text-decoration-none" do %>
                      <span class="badge rounded-pill text-bg-primary post-card__tag"><%= tag.name %></span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>

              <div class="post-card__footer d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 pt-2 mt-auto">
                <div class="text-muted small">
                  投稿者：<%= post.user.name %><br>
                  投稿日時：<%= post.created_at.strftime("%Y-%m-%d %H:%M") %>
                </div>

                <%= link_to "詳細を見る", post_path(post), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-light border mb-0">まだ投稿はありません。</div>
  <% end %>
</div>