<%= turbo_frame_tag dom_id(post, :comment_form) do %>
  <% if current_user %>
    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">コメントを投稿する</h5>

        <%= form_with model: comment do |f| %>
          <%= f.hidden_field :post_id, value: post.id %>

          <div class="mb-2">
            <%= f.text_area :body, rows: 3, class: "form-control", placeholder: "コメントを入力してください" %>
            <% if comment.errors[:body].present? %>
              <div class="text-danger small mt-1"><%= comment.errors[:body].first %></div>
            <% end %>
          </div>

          <%= f.submit "送信", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <p>
      <%= link_to "ログイン", login_path %>するとコメントできます。
    </p>
  <% end %>
<% end %>
