<%= turbo_frame_tag dom_id(post, :favorite_button_show) do %>
  <% if current_user %>
    <% if post.favorited_by?(current_user) %>
      <%= button_to "❤️", post_favorite_path(post), method: :delete, class: "btn btn-outline-danger", title: "いいねを取り消す" %>
    <% else %>
      <%= button_to "♡", post_favorite_path(post), method: :post, class: "btn btn-outline-danger", title: "いいねする" %>
    <% end %>
  <% end %>
<% end %>
