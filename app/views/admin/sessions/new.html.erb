<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="h4 text-center mb-4">管理者ログイン</h2>

        <%= form_with url: admin_login_path, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :login_id, "管理者ID", class: "form-label" %>
            <%= f.text_field :login_id, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "パスワード", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>

          <%= f.submit "ログイン", class: "btn btn-secondary w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>