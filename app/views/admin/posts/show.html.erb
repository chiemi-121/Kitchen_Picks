<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">投稿詳細</h1>
    <p class="text-muted mb-0">投稿内容とコメントを確認し、必要に応じて削除できます。</p>
  </div>
  <%= link_to "レビュー一覧へ戻る", admin_posts_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h2 class="h4"><%= @post.title %></h2>
    <p class="text-muted mb-3">
      投稿者：<%= @post.user.name %><br>
      カテゴリー：<%= @post.category.name %><br>
      評価：<%= "★" * @post.rating %><%= "☆" * (5 - @post.rating) %><br>
      投稿日：<%= @post.created_at.strftime("%Y-%m-%d %H:%M") %>
    </p>

    <% if @post.images.attached? %>
      <div class="d-flex gap-3 flex-wrap mb-3">
        <% @post.images.each do |image| %>
          <%= image_tag url_for(image), class: "img-thumbnail", width: 220 %>
        <% end %>
      </div>
    <% end %>

    <p><%= simple_format(@post.body) %></p>

    <p class="mb-4">
      <% @post.tags.each do |tag| %>
        <span class="badge bg-primary me-1"><%= tag.name %></span>
      <% end %>
    </p>

    <%= button_to "レビューを削除", admin_post_path(@post),
        method: :delete,
        data: { confirm: "このレビューを削除しますか？" },
        class: "btn btn-danger" %>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <h3 class="h5 mb-3">コメント一覧（<%= @comments.count %>件）</h3>

    <% if @comments.any? %>
      <ul class="list-group">
        <% @comments.each do |comment| %>
          <li class="list-group-item d-flex justify-content-between align-items-start">
            <div>
              <div class="fw-bold"><%= comment.user.name %></div>
              <div><%= simple_format(comment.body) %></div>
              <small class="text-muted"><%= comment.created_at.strftime("%Y-%m-%d %H:%M") %></small>
            </div>

            <%= button_to "コメント削除", admin_comment_path(comment),
                method: :delete,
                data: { confirm: "このコメントを削除しますか？" },
                class: "btn btn-sm btn-outline-danger" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">コメントはまだありません。</p>
    <% end %>
  </div>
</div>