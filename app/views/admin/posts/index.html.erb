<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">レビュー一覧</h1>
    <p class="text-muted mb-0">全ユーザーのレビュー投稿を確認できます。</p>
  </div>
  <%= link_to "ダッシュボードへ戻る", admin_root_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>レビューID</th>
          <th>タイトル</th>
          <th>投稿者</th>
          <th>評価</th>
          <th>コメント数</th>
          <th>投稿日</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @posts.each do |post| %>
          <tr>
            <td><%= post.id %></td>
            <td><%= truncate(post.title, length: 30) %></td>
            <td><%= post.user.name %></td>
            <td><%= "★" * post.rating %><%= "☆" * (5 - post.rating) %></td>
            <td><%= post.comments.size %></td>
            <td><%= post.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="text-end"><%= link_to "詳細", admin_post_path(post), class: "btn btn-sm btn-outline-secondary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>