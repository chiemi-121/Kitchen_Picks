<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">ユーザー一覧</h1>
    <p class="text-muted mb-0">登録中の全ユーザーを表示し、利用状況を確認できます。</p>
  </div>
  <%= link_to "ダッシュボードへ戻る", admin_root_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>ユーザーID</th>
          <th>ユーザー名</th>
          <th>投稿数</th>
          <th>コメント数</th>
          <th>利用状況</th>
          <th>登録日時</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.name %></td>
            <td><%= user.posts.size %></td>
            <td><%= user.comments.size %></td>
            <td>
              <% if user.is_active? %>
                <span class="badge bg-success">利用中</span>
              <% else %>
                <span class="badge bg-secondary">停止中</span>
              <% end %>
            </td>
            <td><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="text-end">
              <%= link_to "詳細", admin_user_path(user), class: "btn btn-sm btn-outline-secondary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>