<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">ユーザー詳細</h1>
    <p class="text-muted mb-0">ユーザー情報を確認し、必要に応じて利用停止を行えます。</p>
  </div>
  <%= link_to "ユーザー一覧へ戻る", admin_users_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <dl class="row mb-4">
      <dt class="col-sm-3">ユーザーID</dt>
      <dd class="col-sm-9"><%= @user.id %></dd>

      <dt class="col-sm-3">ユーザー名</dt>
      <dd class="col-sm-9"><%= @user.name %></dd>

      <dt class="col-sm-3">メールアドレス</dt>
      <dd class="col-sm-9"><%= @user.email %></dd>

      <dt class="col-sm-3">投稿数</dt>
      <dd class="col-sm-9"><%= @user.posts.count %></dd>

      <dt class="col-sm-3">コメント数</dt>
      <dd class="col-sm-9"><%= @user.comments.count %></dd>

      <dt class="col-sm-3">利用状況</dt>
      <dd class="col-sm-9">
        <% if @user.is_active? %>
          <span class="badge bg-success">利用中</span>
        <% else %>
          <span class="badge bg-secondary">停止中</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">登録日時</dt>
      <dd class="col-sm-9"><%= @user.created_at.strftime("%Y-%m-%d %H:%M") %></dd>
    </dl>

    <% if @user.is_active? %>
      <%= button_to "利用停止にする", deactivate_admin_user_path(@user),
          method: :patch,
          data: { confirm: "このユーザーを利用停止にしますか？以後ログインできなくなります。" },
          class: "btn btn-danger" %>
    <% else %>
      <%= button_to "利用停止を解除する", activate_admin_user_path(@user),
          method: :patch,
          class: "btn btn-outline-success" %>
    <% end %>
  </div>
</div>